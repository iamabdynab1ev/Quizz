# QUIZ backend environment template.
# Copy this file to `.env` and change values for your machine/server.
# Durations use Go format: `5s`, `1m`, `15m`, `24h`.
# Lists use comma-separated values: `http://localhost:4041,http://192.168.10.79:4041`.

# Application name shown in logs and health responses.
APP_NAME=QUIZ

# Runtime environment label. Common values: `development`, `testing`, `production`.
APP_ENV=development

# Log verbosity. Supported by slog: `DEBUG`, `INFO`, `WARN`, `ERROR`.
LOG_LEVEL=INFO

# HTTP address for the Go backend.
# Local frontend proxy setup uses `127.0.0.1:9000`.
# For direct LAN access use `0.0.0.0:9000`, but prefer Nginx/proxy in production.
HTTP_ADDRESS=127.0.0.1:9000

# Allowed browser origins for CORS.
# Use exact frontend origins in production.
# For local Vite: `http://localhost:4041`.
# `*` allows all origins and is acceptable only for quick local testing.
HTTP_CORS_ALLOWED_ORIGINS=http://localhost:4041

# Maximum time to read the HTTP request body.
HTTP_READ_TIMEOUT=5s

# Maximum time to read HTTP request headers.
HTTP_READ_HEADER_TIMEOUT=2s

# Maximum time to write the HTTP response.
HTTP_WRITE_TIMEOUT=15s

# How long idle keep-alive connections stay open.
HTTP_IDLE_TIMEOUT=60s

# Maximum graceful shutdown time after Ctrl+C/service stop.
HTTP_SHUTDOWN_TIMEOUT=15s

# How long a login session token is valid.
AUTH_SESSION_TTL=24h

# How long authenticated sessions are cached in memory to reduce DB lookups.
# Set `0s` to effectively disable cache.
AUTH_SESSION_CACHE_TTL=5m

# BCrypt password hashing cost.
# Higher is slower and safer. `12` is a good default; local weak machines may use `10`.
AUTH_BCRYPT_COST=12

# Enables/disables temporary login blocking after failed attempts.
# Local frontend testing can set `false`.
# Production should use `true`.
AUTH_LOGIN_LOCKOUT_ENABLED=true

# Failed login attempts allowed before lockout.
# Used only when `AUTH_LOGIN_LOCKOUT_ENABLED=true`.
AUTH_LOGIN_MAX_ATTEMPTS=5

# Time window for counting failed attempts.
# Example: `15m` means 5 failures within 15 minutes cause lockout.
AUTH_LOGIN_ATTEMPT_WINDOW=15m

# How failed login attempts are grouped.
# `identifier` - by email/login only.
# `ip` - by client IP only.
# `identifier_ip` - by email/login OR IP, recommended for production.
AUTH_LOGIN_LOCKOUT_SCOPE=identifier_ip

# Google OAuth Web Client ID.
# Empty disables Google Sign-In in frontend config.
# Example: `1234567890-abc.apps.googleusercontent.com`.
GOOGLE_CLIENT_ID=

# Role assigned to a new user created through Google Sign-In.
# Allowed values: `student`, `guest`, `employee`, `admin`.
# Recommended for this learning platform: `student`.
AUTH_GOOGLE_DEFAULT_ROLE=student

# Directory where uploaded files are stored.
# Static files are served from `/uploads/*`.
UPLOADS_DIR=uploads

# Maximum upload size in megabytes.
UPLOAD_MAX_SIZE_MB=20

# PostgreSQL connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable
# Local Docker example: `postgres://postgres:postgres@127.0.0.1:5433/lms_arvand?sslmode=disable`.
# Local installed Postgres often uses port `5432`.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/lms_arvand?sslmode=disable

# Maximum PostgreSQL connections in the pool.
PGX_MAX_CONNS=20

# Minimum PostgreSQL connections kept warm.
PGX_MIN_CONNS=2

# Maximum lifetime of one DB connection before it is recycled.
PGX_MAX_CONN_LIFETIME=30m

# Maximum idle time before an unused DB connection is closed.
PGX_MAX_CONN_IDLE_TIME=5m

# How often pgx checks connection health.
PGX_HEALTH_CHECK_PERIOD=1m

# Run SQL migrations automatically on backend start.
# Local/dev: `true`.
# Production can use `false` and run migrations separately.
MIGRATE_RUN_ON_START=true

# Directory with migration SQL files.
MIGRATIONS_DIR=migrations

# Create/update bootstrap admin on backend start.
# Local/dev: `true`.
# Production: usually `false` after first setup.
SEED_RUN_ON_START=true

# Bootstrap admin username. Login also supports email.
SEED_ADMIN_USERNAME=admin

# Bootstrap admin email used for first login.
SEED_ADMIN_EMAIL=admin@local.test

# Bootstrap admin password.
# Change this on real server.
SEED_ADMIN_PASSWORD=Admin123!

# Bootstrap admin first name.
SEED_ADMIN_FIRST_NAME=System

# Bootstrap admin last name.
SEED_ADMIN_LAST_NAME=Admin

# Bootstrap admin patronymic/middle name. Leave empty if not used.
SEED_ADMIN_PATRONYMIC=

# Gives bootstrap admin super-admin flag.
SEED_ADMIN_IS_SUPER_ADMIN=true

# Bootstrap admin permissions.
# `*` means all permissions.
# Or use comma-separated permissions if granular permissions are introduced.
SEED_ADMIN_PERMISSIONS=*
